<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <title><%= post.title %> - Blogs by Dagem</title>
</head>
<body>
  <%- include("partials/header.ejs") %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="mb-4">
          <a href="/" class="btn btn-outline-secondary">
            ← Back to Home
          </a>
        </div>

        <article class="blog-post">
          <header class="mb-4">
            <h1 class="display-4 mb-3"><%= post.title %></h1>
            <div class="text-muted mb-3">
              <small>Posted <%= getRelativeTime(post.timestamp) %></small>
            </div>
          </header>

          <% if (post.image) { %>
            <div class="mb-4">
              <% if (post.image.startsWith('/images/')) { %>
                <img src="<%= post.image %>" class="img-fluid rounded" alt="Blog post image">
              <% } else { %>
                <img src="/uploads/<%= post.image %>" class="img-fluid rounded" alt="Blog post image">
              <% } %>
            </div>
          <% } %>

          <div class="blog-content">
            <p class="lead"><%= post.content %></p>
          </div>

          <hr class="my-5">

          <!-- Share and navigation -->
          <div class="d-flex justify-content-between align-items-center">
            <a href="/" class="btn btn-primary">
              ← Back to All Posts
            </a>
          </div>
        </article>
      </div>
    </div>
  </div>

  <%- include("partials/footer.ejs") %>
</body>
</html> 